<?xml version="1.0"?>
<ruleset name="Moyasar PHP">
    <description>Coding standard for moyasar-php</description>

    <arg name="colors"/>
    <arg value="p"/>

    <file>src/</file>
    <file>tests/</file>

    <rule ref="PSR12"/>

    <!-- Pest config file naturally mixes side effects with declarations -->
    <exclude-pattern>tests/Pest.php</exclude-pattern>
</ruleset>
