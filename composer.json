{
    "name": "hamoda-dev/moyasar-php",
    "type": "library",
    "license": "MIT",
    "description": "A simple, expressive PHP client for the Moyasar payment gateway.",
    "authors": [
        {
            "name": "Mohammed Hamoda",
            "email": "hamoda.dev@gmail.com"
        },
        {
            "name": "Abdurrahman Tantawi",
            "email": "abdurrahman.tantawi@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "HamodaDev\\Moyasar\\": "src/",
            "Tests\\": "tests/"
        }
    },
    "require": {
        "saloonphp/saloon": "^4.0",
        "saloonphp/pagination-plugin": "^2.3"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "platform": {
            "php": "8.2.0"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "require-dev": {
        "pestphp/pest": "^3"
    }
}
